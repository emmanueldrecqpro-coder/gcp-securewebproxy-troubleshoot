# Ignore dependency directories
node_modules/
vendor/
target/
dist/
build/
.gradle/
.mvn/

# Ignore environment and secret files
.env
.env.*
*.key
*.pem
secrets/
config/credentials/

# Ignore compiled, generated, or binary files
*.class
*.o
*.so
*.dll
*.exe
*.pyc
*.min.js
*.bundle.js

# Ignore logs and temporary files
*.log
*.tmp
.cache/
tmp/

# Ignore large assets
assets/images/
assets/videos/
assets/audio/
*.png
*.jpg
*.gif
*.mp4
*.zip

# Ignore test assets
__snapshots__/
test/fixtures/
tests/data/

# Ignore documentation or metadata
docs/
*.pdf

# Ignore project-specific stuff
private/
local/
